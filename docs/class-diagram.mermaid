classDiagram
  class Lineup {
    +int id
    +string title
    +string map
    +string side
    +string agent
    +string role
    +string[] tags
    +int likes_count
    +int favorites_count
  }
  class UserSession {
    +string access_token
    +string token_type
    +int user_id
    +string openid
    +string provider
  }
  class FilterState {
    +string keyword
    +string map
    +string side
    +string agent
    +int page
  }
  class MiniApiClient {
    +string baseUrl
    +request(method,path,query,body)
    +setToken(token)
    +getLineups(filter)
    +getLineupDetail(id)
    +mpLogin(code)
    +toggleFavorite(id)
    +toggleLike(id)
  }
  class AuthStore {
    +UserSession session
    +bool isLoggedIn
    +hydrate()
    +loginWithWechat()
    +logout()
  }
  class LineupService {
    +list_lineups(filters,user)
    +get_lineup(id,user)
  }
  class AuthService {
    +wechat_login(code)
    +mock_wechat_login(mock_openid)
    +issue_access_token(user)
  }
  class SocialService {
    +favorite(user_id,lineup_id)
    +unfavorite(user_id,lineup_id)
    +like(user_id,lineup_id)
    +unlike(user_id,lineup_id)
  }
  class WechatClient {
    +code2session(code)
  }
  AuthStore --> UserSession
  AuthStore --> MiniApiClient
  MiniApiClient --> Lineup
  MiniApiClient --> FilterState
  LineupService --> Lineup
  AuthService --> WechatClient
  SocialService --> Lineup
