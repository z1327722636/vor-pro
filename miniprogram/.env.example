# WeChat Mini Program API base URL.
# Default (in src/services/api.ts) is https://localhost:8443/api, which
# matches the local HTTPS backend started by `bash scripts/dev-backend-https.sh`.
# Override here if you need to point at a remote/staging backend.
#
# WeChat Mini Program <image> tags require HTTPS, so do NOT use http://
# unless you are debugging the image-loading rejection itself.
TARO_APP_API_BASE_URL=https://localhost:8443/api
