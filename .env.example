# App
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:2367
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ADMIN_EMAIL=
ADMIN_PASSWORD=

# PostgreSQL
POSTGRES_USER=vor
POSTGRES_PASSWORD=vor_password
POSTGRES_DB=vor
DATABASE_URL=postgresql+asyncpg://vor:vor_password@postgres:5432/vor

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
WORKER_ENQUEUE_ENABLED=false
# 0 means parse all detected triplets; set a positive number to cap VLM cost.
MAX_AUTO_TRIPLETS_PER_JOB=0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=vor_minio
MINIO_SECRET_KEY=vor_minio_password
MINIO_BUCKET=lineup-assets
MINIO_SECURE=false

# VLM
LITELLM_MODEL=qwen/qwen2.5-vl-72b-instruct
DASHSCOPE_API_KEY=
OPENAI_API_KEY=

# External video services
# Optional: proxy service for Douyin video search. Expected endpoint: GET {DOUYIN_API_BASE_URL}/api/search?keyword=...&limit=...
DOUYIN_API_BASE_URL=
BILIBILI_SESSDATA=

# WeChat Mini Program login
WECHAT_APPID=
WECHAT_SECRET=
WECHAT_LOGIN_MOCK=true
