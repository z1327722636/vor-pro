# App
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:2367
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Optional: bind the seeded admin to a WeChat Mini Program identity.
# For local mock admin login, set WECHAT_MOCK_OPENID to the same value.
ADMIN_WECHAT_OPENID=
ADMIN_WECHAT_UNIONID=

# PostgreSQL
POSTGRES_USER=vor
POSTGRES_PASSWORD=vor_password
POSTGRES_DB=vor
DATABASE_URL=postgresql+asyncpg://vor:vor_password@postgres:5432/vor

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=vor_minio
MINIO_SECRET_KEY=vor_minio_password
MINIO_BUCKET=lineup-assets
MINIO_SECURE=false

# External video services
# B站用于 yt-dlp 下载视频时携带 cookie
BILIBILI_SESSDATA=

# WeChat Mini Program login
WECHAT_APPID=
WECHAT_SECRET=
# Development only. Set true locally if you do not have real WeChat credentials.
WECHAT_LOGIN_MOCK=false
# Optional stable mock identity. Useful for binding local Mini Program login to ADMIN_WECHAT_OPENID.
WECHAT_MOCK_OPENID=
WECHAT_MOCK_UNIONID=
